# Server / broker tasks (Phase 2 — Raspberry Pi side).
# Invoke from the repo root as `just server <recipe>`, or from server/ as `just <recipe>`.
set shell := ["bash", "-uc"]

# System python for the mock-publisher venv (the Homebrew python is broken here).
py := "/usr/bin/python3"

# Show available recipes
default:
    @just --list

# --- Go service (ingest + DB + website/API) --------------------------------

# Build the server binary (server/wtwlt-server)
build:
    cd {{source_directory()}} && go build -ldflags "-X main.version=$(git describe --tags --always 2>/dev/null || echo dev)" -o wtwlt-server .

# Run the server locally (reads WTWLT_* env; defaults to localhost broker)
run:
    cd {{source_directory()}} && go run .

# Run Go unit tests
test:
    cd {{source_directory()}} && go test ./...

# Vet + tidy check
vet:
    cd {{source_directory()}} && go vet ./...

# Update go.mod/go.sum
tidy:
    cd {{source_directory()}} && go mod tidy

# --- Local broker + mock station (dev, no hardware) ------------------------

# One-time: create the Python venv for the mock publisher (paho-mqtt)
setup:
    cd {{source_directory()}} && {{py}} -m venv .venv && .venv/bin/pip install -q --upgrade pip -r requirements.txt && echo "mock-publisher venv ready (run: just server mock)"

# Start the local Mosquitto broker in the foreground (Ctrl-C to stop).
# Requires: brew install mosquitto
broker:
    cd {{source_directory()}} && mkdir -p data && mosquitto -c mosquitto/mosquitto.conf

# Subscribe to all station topics (run in a second terminal).
watch:
    mosquitto_sub -h localhost -t 'wtwlt/#' -v

# Run the mock weather-station publisher (Ctrl-C to stop).
# Pass extra args after the recipe, e.g.  just server mock --interval 60
mock *args:
    cd {{source_directory()}} && .venv/bin/python mock_publisher.py {{args}}
